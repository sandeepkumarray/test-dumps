🔌 Connection Factory
MqConnectionFactory.cs
C#
using IBM.WMQ;

public class MqConnectionFactory
{
    private readonly MqOptions _options;

    public MqConnectionFactory(IOptions<MqOptions> options)
    {
        _options = options.Value;
    }

    public MQQueueManager Create()
    {
        var props = new Hashtable
        {
            { MQC.HOST_NAME_PROPERTY, _options.ConnectionName.Split('(')[0] },
            { MQC.PORT_PROPERTY, int.Parse(_options.ConnectionName.Split('(')[1].TrimEnd(')')) },
            { MQC.CHANNEL_PROPERTY, _options.Channel },
            { MQC.USER_ID_PROPERTY, _options.User },
            { MQC.PASSWORD_PROPERTY, _options.Password },
            { MQC.TRANSPORT_PROPERTY, MQC.TRANSPORT_MQSERIES_CLIENT }
        };

        return new MQQueueManager(_options.QueueManager, props);
    }
}
