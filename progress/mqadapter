using IBM.WMQ;
using Polly;

public class MqConsumer : IMqConsumer
{
    private readonly MqConnectionFactory _factory;
    private readonly MqOptions _options;
    private readonly ILogger<MqConsumer> _logger;

    public MqConsumer(
        MqConnectionFactory factory,
        IOptions<MqOptions> options,
        ILogger<MqConsumer> logger)
    {
        _factory = factory;
        _options = options.Value;
        _logger = logger;
    }

    public async Task StartAsync(Func<byte[], Task> handler, CancellationToken cancellationToken)
    {
        using var qm = _factory.Create();

        int openOptions = MQC.MQOO_INPUT_AS_Q_DEF | MQC.MQOO_FAIL_IF_QUIESCING;
        using var queue = qm.AccessQueue(_options.QueueName, openOptions);

        var gmo = new MQGetMessageOptions
        {
            Options = MQC.MQGMO_WAIT,
            WaitInterval = 5000
        };

        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                var message = new MQMessage();
                queue.Get(message, gmo);

                var buffer = new byte[message.DataLength];
                message.ReadFully(ref buffer);

                await handler(buffer);
            }
            catch (MQException ex) when (ex.ReasonCode == MQC.MQRC_NO_MSG_AVAILABLE)
            {
                continue;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error consuming MQ message");
                await Task.Delay(1000, cancellationToken);
            }
        }
    }
}
