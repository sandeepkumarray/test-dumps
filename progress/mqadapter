ServiceCollectionExtensions.cs
C#
public static class ServiceCollectionExtensions
{
    public static IServiceCollection AddMqSharp(this IServiceCollection services, IConfiguration config)
    {
        services.Configure<MqOptions>(config.GetSection("Mq"));

        services.AddSingleton<MqConnectionFactory>();
        services.AddSingleton<IMessageSerializer, JsonMessageSerializer>();

        services.AddSingleton<IMqProducer, MqProducer>();

        return services;
    }

    // 🔥 Register typed consumer
    public static IServiceCollection AddMqConsumer<T>(this IServiceCollection services)
    {
        services.AddSingleton<IMqConsumer<T>, MqConsumer<T>>();
        services.AddHostedService<MqConsumerBackgroundService<T>>();

        return services;
    }

    // 🔥 Register handler
    public static IServiceCollection AddMqHandler<T, THandler>()
        where THandler : class, IMqMessageHandler<T>
    {
        services.AddScoped<IMqMessageHandler<T>, THandler>();
        return services;
    }
}
