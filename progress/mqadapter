MqProducer.cs
C#
using IBM.WMQ;
using Polly;

public class MqProducer : IMqProducer
{
    private readonly MqConnectionFactory _factory;
    private readonly IMessageSerializer _serializer;
    private readonly MqOptions _options;
    private readonly IAsyncPolicy _retryPolicy;

    public MqProducer(
        MqConnectionFactory factory,
        IMessageSerializer serializer,
        IOptions<MqOptions> options)
    {
        _factory = factory;
        _serializer = serializer;
        _options = options.Value;

        _retryPolicy = Policy
            .Handle<Exception>()
            .WaitAndRetryAsync(3, retry => TimeSpan.FromSeconds(retry));
    }

    public async Task SendAsync<T>(T message, CancellationToken cancellationToken = default)
    {
        await _retryPolicy.ExecuteAsync(async () =>
        {
            using var qm = _factory.Create();

            int openOptions = MQC.MQOO_OUTPUT;
            using var queue = qm.AccessQueue(_options.QueueName, openOptions);

            var mqMessage = new MQMessage();
            mqMessage.Write(_serializer.Serialize(message));

            var pmo = new MQPutMessageOptions();

            queue.Put(mqMessage, pmo);

            await Task.CompletedTask;
        });
    }
}
