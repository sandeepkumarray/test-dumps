public class UserCreatedHandler : IMqTopicHandler<UserCreated>
{
    private readonly ILogger<UserCreatedHandler> _logger;

    public UserCreatedHandler(ILogger<UserCreatedHandler> logger)
    {
        _logger = logger;
    }

    public Task HandleAsync(UserCreated message, CancellationToken cancellationToken)
    {
        _logger.LogInformation("User created: {UserId}", message.UserId);
        return Task.CompletedTask;
    }
}
Program.cs
C#
var builder = Host.CreateApplicationBuilder(args);

builder.Services.AddMqSharp(builder.Configuration);
builder.Services.AddMqPubSub();

// Subscriber
builder.Services.AddMqSubscriber<UserCreated>("topic://user/events");
builder.Services.AddMqTopicHandler<UserCreated, UserCreatedHandler>();

var app = builder.Build();

// Publisher
var publisher = app.Services.GetRequiredService<IMqPublisher>();

await publisher.PublishAsync("topic://user/events", new UserCreated
{
    UserId = "U123"
});

await app.RunAsync();
