📤 1. Topic Publisher
IMqPublisher
C#
public interface IMqPublisher
{
    Task PublishAsync<T>(string topic, T message, CancellationToken cancellationToken = default);
}
MqPublisher
C#
using IBM.WMQ;
using Polly;

public class MqPublisher : IMqPublisher
{
    private readonly MqConnectionFactory _factory;
    private readonly IMessageSerializer _serializer;

    public MqPublisher(MqConnectionFactory factory, IMessageSerializer serializer)
    {
        _factory = factory;
        _serializer = serializer;
    }

    public async Task PublishAsync<T>(string topic, T message, CancellationToken cancellationToken = default)
    {
        using var qm = _factory.Create();

        int openOptions = MQC.MQOO_OUTPUT;
        using var topicObj = qm.AccessTopic(topic, null, openOptions);

        var mqMessage = new MQMessage();
        mqMessage.Write(_serializer.Serialize(message));

        var pmo = new MQPutMessageOptions();

        topicObj.Put(mqMessage, pmo);

        await Task.CompletedTask;
    }
}
