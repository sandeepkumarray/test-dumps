MqSubscriber<T>
C#
using IBM.WMQ;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Logging;

public class MqSubscriber<T> : IMqSubscriber<T>
{
    private readonly MqConnectionFactory _factory;
    private readonly IMessageSerializer _serializer;
    private readonly IServiceScopeFactory _scopeFactory;
    private readonly ILogger<MqSubscriber<T>> _logger;

    public MqSubscriber(
        MqConnectionFactory factory,
        IMessageSerializer serializer,
        IServiceScopeFactory scopeFactory,
        ILogger<MqSubscriber<T>> logger)
    {
        _factory = factory;
        _serializer = serializer;
        _scopeFactory = scopeFactory;
        _logger = logger;
    }

    public async Task StartAsync(string topic, CancellationToken cancellationToken)
    {
        using var qm = _factory.Create();

        int openOptions = MQC.MQSO_CREATE | MQC.MQSO_NON_DURABLE;

        var subDesc = new MQSubscriptionDescriptor
        {
            Options = openOptions,
            ObjectString = topic
        };

        using var subscription = qm.AccessSubscription(subDesc, null, null);

        using var queue = subscription.ManagedQueue;

        var gmo = new MQGetMessageOptions
        {
            Options = MQC.MQGMO_WAIT,
            WaitInterval = 5000
        };

        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                var mqMessage = new MQMessage();
                queue.Get(mqMessage, gmo);

                var buffer = new byte[mqMessage.DataLength];
                mqMessage.ReadFully(ref buffer);

                var message = _serializer.Deserialize<T>(buffer);

                using var scope = _scopeFactory.CreateScope();

                var handlers = scope.ServiceProvider
                    .GetServices<IMqTopicHandler<T>>();

                foreach (var handler in handlers)
                {
                    await handler.HandleAsync(message, cancellationToken);
                }
            }
            catch (MQException ex) when (ex.ReasonCode == MQC.MQRC_NO_MSG_AVAILABLE)
            {
                continue;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in topic subscriber for {Type}", typeof(T).Name);
                await Task.Delay(1000, cancellationToken);
            }
        }
    }
}
🔄 3. Background Service for Subscriber
MqSubscriberBackgroundService<T>
C#
using Microsoft.Extensions.Hosting;

public class MqSubscriberBackgroundService<T> : BackgroundService
{
    private readonly IMqSubscriber<T> _subscriber;
    private readonly string _topic;

    public MqSubscriberBackgroundService(IMqSubscriber<T> subscriber, string topic)
    {
        _subscriber = subscriber;
        _topic = topic;
    }

    protected override Task ExecuteAsync(CancellationToken stoppingToken)
    {
        return _subscriber.StartAsync(_topic, stoppingToken);
    }
}
🔌 4. DI Extensions
C#
public static class ServiceCollectionExtensions
{
    public static IServiceCollection AddMqPubSub(this IServiceCollection services)
    {
        services.AddSingleton<IMqPublisher, MqPublisher>();
        return services;
    }

    public static IServiceCollection AddMqSubscriber<T>(this IServiceCollection services, string topic)
    {
        services.AddSingleton<IMqSubscriber<T>, MqSubscriber<T>>();

        services.AddHostedService(provider =>
            new MqSubscriberBackgroundService<T>(
                provider.GetRequiredService<IMqSubscriber<T>>(),
                topic));

        return services;
    }

    public static IServiceCollection AddMqTopicHandler<T, THandler>(this IServiceCollection services)
        where THandler : class, IMqTopicHandler<T>
    {
        services.AddScoped<IMqTopicHandler<T>, THandler>();
        return services;
    }
}
